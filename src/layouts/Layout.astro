---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

export interface Props {
  title: string;
  description: string;
  activeNav?: string;
  /** Tipo de Open Graph: 'website' (default) o 'article' para posts del blog */
  type?: string;
  /** Imagen para previews al compartir. Ruta relativa (ej: '/og-image.jpg') o absoluta */
  image?: string;
  /** Fecha de publicación (solo artículos) */
  publishedTime?: string;
}

const {
  title,
  description,
  activeNav,
  type = 'website',
  image = '/og-image.jpg',
  publishedTime,
} = Astro.props;

// URL canónica limpia
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href.replace(/\/$/, '') || Astro.site;
// Imagen absoluta para Open Graph (las redes exigen URL completa)
const socialImage = new URL(image, Astro.site).href;

// Schema de negocio local: ayuda a Google a entender que es un servicio de Lima (refuerza el pack local).
const localBusinessSchema = {
  "@context":"https://schema.org","@type":["LocalBusiness","MusicSchool"],
  "@id":"https://profesormvt.com/#business",
  "name":"ProfesorMVT",
  "alternateName":"Andrés Salamé-Córdova · Clases de canto, piano y composición",
  "description":"Clases 1 a 1 de canto (método MVT), piano y composición para adultos en Lima (San Isidro) y online.",
  "url":"https://profesormvt.com/",
  "telephone":"+51989077928",
  "image":"https://profesormvt.com/og-image.jpg",
  "priceRange":"S/50 - S/600",
  "areaServed":[{"@type":"City","name":"Lima"},{"@type":"AdministrativeArea","name":"Lima Metropolitana"}],
  "address":{"@type":"PostalAddress","addressLocality":"San Isidro","addressRegion":"Lima","addressCountry":"PE"},
  "geo":{"@type":"GeoCoordinates","latitude":-12.0976,"longitude":-77.0365},
  "knowsAbout":["Clases de canto","Técnica vocal MVT","Clases de piano","Composición musical"],
  "sameAs":[
    "https://www.instagram.com/asalamecordova/",
    "https://www.facebook.com/profile.php?id=61588980507102",
    "https://www.tiktok.com/@profesormvt.com"
  ]
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />

  <!-- Meta Pixel Code -->
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1281275673536185');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1281275673536185&ev=PageView&noscript=1"/></noscript>
  <!-- End Meta Pixel Code -->

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={socialImage} />
  <meta property="og:locale" content="es_PE" />
  <meta property="og:site_name" content="Profesor MVT" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Fuentes de marca (el global.css las usa pero no las cargaba en las páginas con Layout) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Fraunces:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} is:inline></script>
</head>
<body>
  <Nav activeNav={activeNav} />
  <slot />
  <Footer />
  <WhatsAppFloat />
</body>
</html>
