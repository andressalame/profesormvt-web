---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

export interface Props {
  title: string;
  description: string;
  activeNav?: string;
}

const { title, description, activeNav } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO básico -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="clases de canto Lima, vocal coaching MVT, clases de piano adultos, Faber Faber piano, composición Hook Theory, profesor música San Isidro, clases música online Perú" />
  <meta name="author" content="Andrés Salame" />
  <link rel="canonical" href="https://profesormvt.com/" />

  <!-- Open Graph (Facebook, Instagram, WhatsApp, LinkedIn) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://profesormvt.com/" />
  <meta property="og:title" content="Profesor MVT — Clases de música para adultos en Lima y online" />
  <meta property="og:description" content="Clases de canto con método MVT, piano con Faber & Faber, composición con Hook Theory. Para adultos que quieren tomarse la música en serio. Clase de prueba S/50." />
  <meta property="og:image" content="https://profesormvt.com/andres-piano-hero.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Andrés Salame, profesor de música, sentado al piano en su estudio" />
  <meta property="og:locale" content="es_PE" />
  <meta property="og:site_name" content="Profesor MVT" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="https://profesormvt.com/" />
  <meta name="twitter:title" content="Profesor MVT — Clases de música para adultos en Lima y online" />
  <meta name="twitter:description" content="Clases de canto con método MVT, piano con Faber & Faber, composición con Hook Theory. Para adultos que quieren tomarse la música en serio. Clase de prueba S/50." />
  <meta name="twitter:image" content="https://profesormvt.com/andres-piano-hero.jpg" />
  <meta name="twitter:image:alt" content="Andrés Salame, profesor de música, sentado al piano en su estudio" />

  <!-- Meta Pixel Code -->
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1281275673536185');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1281275673536185&ev=PageView&noscript=1"
  /></noscript>
  <!-- End Meta Pixel Code -->

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Structured Data (JSON-LD) — Schema.org para Google -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "Profesor MVT",
    "description": "Clases de canto con método MVT, piano con Faber & Faber, composición con Hook Theory y teoría musical para adultos.",
    "url": "https://profesormvt.com",
    "logo": "https://profesormvt.com/andres-piano-hero.jpg",
    "image": "https://profesormvt.com/andres-piano-hero.jpg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "San Isidro",
      "addressRegion": "Lima",
      "addressCountry": "PE"
    },
    "founder": {
      "@type": "Person",
      "name": "Andrés Salame",
      "jobTitle": "Profesor de música"
    },
    "sameAs": [
      "https://instagram.com/asalamecordova",
      "https://tiktok.com/@profesordecantomvt"
    ],
    "offers": {
      "@type": "Offer",
      "name": "Clase de prueba",
      "price": "50",
      "priceCurrency": "PEN"
    }
  }
  </script>
</head>
<body>
  <Nav activeNav={activeNav} />
  <slot />
  <Footer />
  <WhatsAppFloat />

  <!-- Meta Pixel — Custom Event Tracking -->
  <script>
    // Track WhatsApp clicks as Lead events
    document.addEventListener('DOMContentLoaded', function() {
      // Encuentra TODOS los links que apunten a wa.me o whatsapp
      const whatsappLinks = document.querySelectorAll('a[href*="wa.me"], a[href*="whatsapp.com"], a[href*="api.whatsapp.com"]');

      whatsappLinks.forEach(link => {
        link.addEventListener('click', function() {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'Lead', {
              content_name: 'WhatsApp Click',
              content_category: 'Contact'
            });
          }
        });
      });

      // Track Calendly clicks as Schedule events
      const calendlyLinks = document.querySelectorAll('a[href*="calendly.com"]');

      calendlyLinks.forEach(link => {
        link.addEventListener('click', function() {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'Schedule', {
              content_name: 'Calendly Click',
              content_category: 'Booking'
            });
          }
        });
      });
    });
  </script>
</body>
</html>
