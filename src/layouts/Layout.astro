---
// ═══════════════════════════════════════════════════════════
// Layout principal del sitio Profesor MVT
// Incluye: meta tags SEO, Open Graph, Twitter Cards, geo tags
// ═══════════════════════════════════════════════════════════

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Profesor MVT en Lima · Canto, piano y composición para adultos",
  description = "Clases de canto (técnica MVT), piano y composición para adultos en Lima (San Isidro) y online. Con Andrés Salame. Prueba con diagnóstico vocal en PDF.",
  image = "/og-image.jpg",
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteURL = "https://profesormvt.com";
const fullImageURL = image.startsWith("http") ? image : `${siteURL}${image}`;
---

<!doctype html>
<html lang="es-PE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- ═══════════ PRIMARY META ═══════════ -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- ═══════════ OPEN GRAPH (Facebook, WhatsApp, LinkedIn) ═══════════ -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Profesor MVT — Clases de canto, piano y composición para adultos en Lima" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Profesor MVT" />

    <!-- ═══════════ TWITTER / X CARD ═══════════ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageURL} />
    <meta name="twitter:image:alt" content="Profesor MVT — Clases de canto, piano y composición para adultos en Lima" />

    <!-- ═══════════ SEO TÉCNICO ═══════════ -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="Andrés Salame" />
    <meta http-equiv="Content-Language" content="es-PE" />
    <link rel="canonical" href={canonicalURL} />

    <!-- ═══════════ GEO TAGS (negocio local Lima) ═══════════ -->
    <meta name="geo.region" content="PE-LIM" />
    <meta name="geo.placename" content="San Isidro, Lima, Perú" />
    <meta name="geo.position" content="-12.0931;-77.0465" />
    <meta name="ICBM" content="-12.0931, -77.0465" />

    <!-- ═══════════ STRUCTURED DATA (JSON-LD) ═══════════ -->
    <!-- Le dice a Google que eres un negocio local con servicios -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${siteURL}/#business`,
      "name": "Profesor MVT",
      "alternateName": "Andrés Salame — Profesor MVT",
      "description": description,
      "url": siteURL,
      "telephone": "+51-XXX-XXX-XXX",
      "image": fullImageURL,
      "priceRange": "S/50 - S/450",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. Salaverry / Av. JV Prado",
        "addressLocality": "San Isidro",
        "addressRegion": "Lima",
        "addressCountry": "PE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -12.0931,
        "longitude": -77.0465
      },
      "areaServed": [
        { "@type": "City", "name": "Lima" },
        { "@type": "Country", "name": "Perú" }
      ],
      "founder": {
        "@type": "Person",
        "name": "Andrés Salame",
        "jobTitle": "Profesor de música — canto MVT, piano y composición",
        "sameAs": [
          "https://instagram.com/asalamecordova",
          "https://tiktok.com/@profesordecantomvt"
        ]
      },
      "sameAs": [
        "https://instagram.com/profesordecantomvt",
        "https://tiktok.com/@profesordecantomvt"
      ]
    })} />

    <!-- Servicios que ofreces -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Clases de canto, piano y composición",
      "provider": { "@id": `${siteURL}/#business` },
      "areaServed": "Lima, Perú",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Paquetes de clases",
        "itemListElement": [
          {
            "@type": "Offer",
            "name": "Clase de prueba",
            "price": "50",
            "priceCurrency": "PEN",
            "description": "Incluye diagnóstico vocal escrito en PDF"
          },
          {
            "@type": "Offer",
            "name": "Esencial",
            "price": "250",
            "priceCurrency": "PEN",
            "description": "4 horas al mes (1 clase semanal)"
          },
          {
            "@type": "Offer",
            "name": "Intensivo",
            "price": "450",
            "priceCurrency": "PEN",
            "description": "8 horas al mes (2 clases semanales)"
          },
          {
            "@type": "Offer",
            "name": "Lock-In Trimestral Esencial",
            "price": "625",
            "priceCurrency": "PEN",
            "description": "12 horas en 3 meses, mes 3 al 50%"
          },
          {
            "@type": "Offer",
            "name": "Lock-In Trimestral Intensivo",
            "price": "1125",
            "priceCurrency": "PEN",
            "description": "24 horas en 3 meses, mes 3 al 50%"
          }
        ]
      }
    })} />

    <!-- ═══════════ FAVICONS COMPLETOS ═══════════ -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <meta name="theme-color" content="#0F0F0E" />

    <!-- ═══════════ PRECONNECT (mejora velocidad) ═══════════ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- ═══════════ META PIXEL (ya instalado en el sitio) ═══════════ -->
    <!-- Tu Meta Pixel + Conversions API ya están corriendo. Si no, ponlos aquí. -->
  </head>

  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Reset básico */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    background: #0F0F0E;
    color: #EBE5D6;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
</style>
