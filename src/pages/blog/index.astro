---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import '../../styles/blog.css';

// Traer todos los posts del blog (excluyendo borradores)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Ordenar por fecha descendente (más reciente primero)
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Separar el destacado del resto
const featured = posts.find(p => p.data.featured) || posts[0];
const others = posts.filter(p => p.slug !== featured?.slug);

// Mapeo de categoría → label visible y clase de color
const categoryMeta: Record<string, { label: string; cls: string }> = {
  voz: { label: 'VOZ', cls: '' },
  piano: { label: 'PIANO', cls: 'bg-piano' },
  composicion: { label: 'COMPOSICIÓN', cls: 'bg-comp' },
  teoria: { label: 'TEORÍA', cls: 'bg-teoria' },
  metodo: { label: 'MÉTODO', cls: 'bg-metodo' },
};

const formatDate = (d: Date) => {
  const months = ['ENE', 'FEB', 'MAR', 'ABR', 'MAY', 'JUN', 'JUL', 'AGO', 'SEP', 'OCT', 'NOV', 'DIC'];
  return `${String(d.getDate()).padStart(2, '0')} ${months[d.getMonth()]} ${d.getFullYear()}`;
};
---

<Layout
  title="Blog · Profesor MVT · Apuntes sobre voz, piano y método"
  description="Reflexiones sobre canto (MVT), piano (Faber & Faber), composición (Hook Theory), teoría musical y pedagogía moderna. Por Andrés Salame."
  activeNav="blog"
>

<section class="blog-hero">
  <div class="container">
    <span class="label">apuntes del estudio</span>
    <h1>Apuntes sobre<br>voz, piano y <em>método</em>.</h1>
    <p>
      Notas técnicas, opiniones contraintuitivas y reflexiones pedagógicas sobre
      Modern Vocal Training, Faber &amp; Faber, Hook Theory, y todo lo que implica
      enseñar música a adultos en serio.
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="categories">
      <span class="cat-label">FILTRAR POR:</span>
      <button class="cat-pill active" data-filter="all">Todos</button>
      <button class="cat-pill cat-voz" data-filter="voz"><span class="dot"></span>Voz</button>
      <button class="cat-pill cat-piano" data-filter="piano"><span class="dot"></span>Piano</button>
      <button class="cat-pill cat-comp" data-filter="composicion"><span class="dot"></span>Composición</button>
      <button class="cat-pill cat-teoria" data-filter="teoria"><span class="dot"></span>Teoría</button>
      <button class="cat-pill cat-metodo" data-filter="metodo"><span class="dot"></span>Método</button>
    </div>
  </div>
</section>

{featured && (
  <section class="featured-post" data-cat={featured.data.category}>
    <div class="container">
      <div class="featured-card">
        <a href={`/blog/${featured.slug}`} class={`featured-img ${categoryMeta[featured.data.category].cls}`} style={featured.data.image ? `background-image: url(${featured.data.image}); background-size: cover; background-position: center;` : ''}>
          <span class="featured-img-tag">⭐ DESTACADO</span>
          {!featured.data.image && (
            <>
              <div class="featured-img-pattern"></div>
              <div class="featured-img-text">
                <strong>{featured.data.title}</strong>
              </div>
            </>
          )}
        </a>
        <div class="featured-content">
          <div class="meta">
            <span class="featured-pill">{categoryMeta[featured.data.category].label}</span>
            <span class="dot-sep"></span>
            <span>{featured.data.readTime} LECTURA</span>
          </div>
          <h2><a href={`/blog/${featured.slug}`}>{featured.data.title}</a></h2>
          <p>{featured.data.excerpt}</p>
          <a href={`/blog/${featured.slug}`} class="featured-cta">Leer el post completo</a>
        </div>
      </div>
    </div>
  </section>
)}

<section class="posts-section">
  <div class="container">
    <h3>Últimos posts</h3>
    <div class="posts-grid">
      {others.map((post) => (
        <article class="post-card" data-cat={post.data.category}>
          <a href={`/blog/${post.slug}`} class={`post-img ${categoryMeta[post.data.category].cls}`} style={post.data.image ? `background-image: url(${post.data.image}); background-size: cover; background-position: center;` : ''}>
            <div class="post-img-pattern"></div>
            <span class="post-cat">{categoryMeta[post.data.category].label}</span>
          </a>
          <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
          <p class="post-excerpt">{post.data.excerpt}</p>
          <div class="post-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="dot-sep"></span>
            <span>{post.data.readTime}</span>
          </div>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="empty-state">
        <p>No hay posts publicados todavía. Vuelve pronto.</p>
      </div>
    )}
  </div>
</section>

<section class="cta-strip">
  <div class="container-narrow">
    <h3>¿Una <em>duda específica</em> que no encuentras en el blog?</h3>
    <p>Escríbeme directo por WhatsApp. Te respondo personalmente.</p>
    <a href="https://wa.me/51989077928?text=Hola%20Andr%C3%A9s%2C%20vi%20tu%20blog%20y%20tengo%20una%20pregunta" class="btn">
      <svg viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.594 5.39l-.999 3.648 3.745-.978zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
      Escribir por WhatsApp
    </a>
  </div>
</section>

<script is:inline>
  // Filtro de categorías
  document.querySelectorAll('.cat-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.getAttribute('data-filter');
      document.querySelectorAll('.post-card, .featured-post').forEach(card => {
        const cat = card.getAttribute('data-cat');
        if (filter === 'all' || cat === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

</Layout>
