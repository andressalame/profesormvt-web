---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { getCollection } from 'astro:content';
import '../../styles/blog-post.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryMeta: Record<string, { label: string; color: string }> = {
  voz: { label: 'VOZ', color: 'var(--wine)' },
  piano: { label: 'PIANO', color: 'var(--clay)' },
  composicion: { label: 'COMPOSICIÓN', color: 'var(--slate)' },
  teoria: { label: 'TEORÍA', color: 'var(--gold-deep)' },
  metodo: { label: 'MÉTODO', color: 'var(--forest)' },
};

const formatDate = (d: Date) => {
  const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  return `${d.getDate()} de ${months[d.getMonth()]} de ${d.getFullYear()}`;
};

// Posts relacionados (misma categoría, excluyendo el actual)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const related = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const postImageURL = new URL(post.data.image || '/og-image.jpg', Astro.site).href;
const postURL = new URL(`/blog/${post.slug}/`, Astro.site).href;
---

<Layout
  title={`${post.data.title} · Profesor MVT`}
  description={post.data.excerpt}
  type="article"
  image={post.data.image || '/og-image.jpg'}
  publishedTime={post.data.date.toISOString()}
  activeNav="blog"
>

<article class="post-article">
  <div class="container-narrow">

    <a href="/blog" class="back-link">← Volver al blog</a>

    <header class="post-header">
      <div class="post-meta-top">
        <span class="post-category" style={`background: ${categoryMeta[post.data.category].color};`}>
          {categoryMeta[post.data.category].label}
        </span>
        <span class="post-date">{formatDate(post.data.date)}</span>
        <span class="dot-sep"></span>
        <span class="post-readtime">{post.data.readTime} de lectura</span>
      </div>
      <h1 set:html={post.data.title.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></h1>
      <p class="post-lead">{post.data.excerpt}</p>
    </header>

    {post.data.image && (
      <div class="post-cover">
        <img src={post.data.image} alt={post.data.title} />
      </div>
    )}

    <div class="post-body">
      <Content />
    </div>

    <aside style="max-width:640px;margin:36px auto;padding:26px 24px;background:#15110f;border:1px solid #2A2926;border-left:3px solid #e8501f;border-radius:12px;">
      <h3 style="font-family:'Anton',Impact,sans-serif;text-transform:uppercase;font-size:24px;letter-spacing:.01em;color:#f3ede0;margin:0 0 8px;">¿Listo para dar el paso?</h3>
      <p style="font-family:'Space Grotesk',system-ui,sans-serif;font-size:15.5px;line-height:1.55;color:#cfc7b6;margin:0 0 18px;">Reserva una clase de prueba 1 a 1 con diagnóstico por S/50. Sales sabiendo exactamente qué trabajar, y decides con la oreja.</p>
      <a href="/prueba/?f=blog" style="display:inline-block;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.06em;font-size:13px;font-weight:700;padding:13px 22px;border-radius:6px;background:#e8501f;color:#160a04;text-decoration:none;">Reservar mi clase de prueba →</a>
    </aside>

    <LeadForm fuente="blog" />

    <footer class="post-footer">
      <div class="post-author">
        <img class="author-avatar" src="/andres-avatar.jpg" alt="Andrés Salame" width="48" height="48" loading="lazy" />
        <div class="author-info">
          <div class="author-name">Andrés Salame</div>
          <div class="author-role">Profesor de canto, piano y composición</div>
        </div>
      </div>
      <a href="/horarios/" class="post-cta">
        Reserva tu clase de prueba →
      </a>
    </footer>

  </div>
</article>

{related.length > 0 && (
  <section class="related-section">
    <div class="container-narrow">
      <h3 class="related-title">Sigue leyendo · {categoryMeta[post.data.category].label.toLowerCase()}</h3>
      <div class="related-grid">
        {related.map((p) => (
          <a href={`/blog/${p.slug}`} class="related-card">
            <span class="related-cat" style={`color: ${categoryMeta[p.data.category].color};`}>
              {categoryMeta[p.data.category].label}
            </span>
            <h4>{p.data.title}</h4>
            <span class="related-readtime">{p.data.readTime}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "image": postImageURL,
  "datePublished": post.data.date.toISOString(),
  "dateModified": post.data.date.toISOString(),
  "inLanguage": "es",
  "author": { "@type": "Person", "name": "Andrés Salame", "url": "https://profesormvt.com" },
  "publisher": {
    "@type": "Organization",
    "name": "Profesor MVT",
    "logo": { "@type": "ImageObject", "url": "https://profesormvt.com/logo.png" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": postURL }
})} />

</Layout>
