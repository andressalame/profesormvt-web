<style is:inline>
/* ============ RESET / BASE ============ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0b0a;
  --panel:#15110f;
  --orange:#e8501f;
  --orange2:#ff6a35;
  --cream:#f3ede0;
  --gray:#8a8276;
  --line:#2A2926;
  --radius:2px;
  --maxw:1240px;
  --pad:clamp(20px,5vw,64px);
  --eq-h:clamp(64px,9vh,104px);
  --sticky-nav:64px;
}
html{
  -webkit-text-size-adjust:100%;
  scroll-behavior:smooth;
  scrollbar-color:var(--orange) #100c0a;
}
html,body{background:#0d0b0a}
body{
  font-family:"Space Grotesk",system-ui,sans-serif;
  color:var(--cream);
  line-height:1.5;
  overflow-x:hidden;
  position:relative;
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
}
::selection{background:var(--orange);color:#0d0b0a}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button{font:inherit;color:inherit;cursor:pointer;background:none;border:none}

/* themed scrollbar (webkit) */
::-webkit-scrollbar{width:11px}
::-webkit-scrollbar-track{background:#100c0a}
::-webkit-scrollbar-thumb{background:var(--orange);border:2px solid #100c0a}

/* ============ ATMOSPHERE LAYERS ============ */
.bg-layer{position:fixed;inset:0;z-index:-3;background:var(--bg);will-change:background-color}
.glow{
  position:fixed;left:50%;top:42%;width:120vmax;height:120vmax;z-index:-2;
  transform:translate(-50%,-50%);
  background:radial-gradient(closest-side, rgba(232,80,31,.42), rgba(232,80,31,.12) 42%, transparent 70%);
  opacity:.12;pointer-events:none;will-change:opacity,transform;filter:blur(8px);
}
.grain{
  position:fixed;inset:-120px;z-index:60;pointer-events:none;
  opacity:.06;mix-blend-mode:soft-light;
  animation:grainShift 1.2s steps(3) infinite;
}
@keyframes grainShift{
  0%{transform:translate(0,0)}33%{transform:translate(-30px,18px)}66%{transform:translate(22px,-26px)}100%{transform:translate(0,0)}
}

/* persistent reactive equalizer */
#eq{
  position:fixed;left:0;right:0;bottom:0;height:var(--eq-h);width:100%;
  z-index:40;pointer-events:none;display:block;
  -webkit-mask-image:linear-gradient(to top, #000 38%, transparent);
          mask-image:linear-gradient(to top, #000 38%, transparent);
}
.eq-base{
  position:fixed;left:0;right:0;bottom:0;height:1px;background:var(--line);z-index:41;pointer-events:none;
}

/* ============ TYPE HELPERS ============ */
.mono{font-family:"JetBrains Mono",ui-monospace,monospace;letter-spacing:.18em;text-transform:uppercase}
.eyebrow{
  font-family:"JetBrains Mono",monospace;font-size:clamp(.66rem,1.4vw,.82rem);
  letter-spacing:.32em;text-transform:uppercase;color:var(--orange2);
  display:inline-flex;align-items:center;gap:.7em;margin-bottom:1.6rem;
}
.eyebrow::before{content:"";width:34px;height:2px;background:var(--orange);display:inline-block}
.display{
  font-family:"Anton",Impact,sans-serif;text-transform:uppercase;
  line-height:.95;letter-spacing:-.005em;font-weight:400;
}
.h1{font-size:clamp(3.1rem,12.5vw,11.5rem)}
.h2{font-size:clamp(2.5rem,8.4vw,7rem)}
.h3{font-size:clamp(1.9rem,5vw,3.4rem)}
.fire{color:var(--orange)}
.lead{font-size:clamp(1.05rem,1.7vw,1.3rem);color:#cfc7b6;max-width:62ch}
.sub{font-size:clamp(1.15rem,2.4vw,1.6rem);color:var(--cream);font-weight:500}
.kicker{font-family:"JetBrains Mono",monospace;letter-spacing:.24em;text-transform:uppercase;font-size:.78rem;color:var(--gray)}

/* ============ LAYOUT ============ */
.wrap{max-width:var(--maxw);margin-inline:auto;padding-inline:var(--pad);width:100%}
section{position:relative;z-index:1}
.pad{padding-block:clamp(96px,13vh,170px)}
.screen{min-height:100vh;min-height:100svh;display:flex;align-items:center}
.stage{position:relative}
/* spotlight that "turns on" per section */
.spot{
  position:absolute;inset:0;z-index:0;pointer-events:none;opacity:0;
  background:radial-gradient(60% 55% at 50% 38%, rgba(232,80,31,.16), transparent 70%);
  will-change:opacity;
}
.stage > .wrap{position:relative;z-index:1}

/* ============ BUTTONS ============ */
.btn{
  --bw:2px;
  display:inline-flex;align-items:center;gap:.6em;
  font-family:"JetBrains Mono",monospace;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  font-size:.82rem;padding:1.05em 1.7em;border-radius:var(--radius);
  border:var(--bw) solid var(--cream);position:relative;transition:transform .18s ease, background-color .18s ease, color .18s ease, box-shadow .18s ease;
  will-change:transform;
}
.btn:focus-visible{outline:3px solid var(--orange2);outline-offset:3px}
.btn .arr{transition:transform .2s ease}
.btn:hover .arr{transform:translateX(4px)}
.btn-primary{background:var(--orange);border-color:var(--orange);color:#160a04;box-shadow:6px 6px 0 #000}
.btn-primary:hover{background:var(--orange2);transform:translate(-2px,-2px);box-shadow:9px 9px 0 #000}
.btn-primary:active{transform:translate(2px,2px);box-shadow:3px 3px 0 #000}
.btn-ghost{background:transparent;color:var(--cream)}
.btn-ghost:hover{background:var(--cream);color:#160a04;transform:translate(-2px,-2px)}
.btn-lg{font-size:.95rem;padding:1.25em 2.1em}

/* ============ NAV ============ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:50;height:var(--sticky-nav);
  display:flex;align-items:center;justify-content:space-between;
  padding-inline:var(--pad);
  border-bottom:1px solid transparent;transition:background-color .3s ease, border-color .3s ease, backdrop-filter .3s ease;
}
.nav.scrolled{background:rgba(13,11,10,.72);backdrop-filter:blur(10px);border-bottom-color:var(--line)}
.brand{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:1.15rem;letter-spacing:.04em;display:flex;align-items:center;gap:.55em}
.brand .horns{width:1.1em;height:1.1em;color:var(--orange);flex:none;filter:drop-shadow(0 0 8px var(--orange))}
.nav-links{display:flex;align-items:center;gap:2rem}
.nav-links a.lnk{font-family:"JetBrains Mono",monospace;font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gray);transition:color .2s}
.nav-links a.lnk:hover{color:var(--cream)}
.nav .btn{padding:.7em 1.15em;font-size:.72rem}

/* ============ HERO ============ */
.hero{padding-top:calc(var(--sticky-nav) + 4vh)}
.hero .wrap{display:flex;flex-direction:column;justify-content:center;min-height:100svh;padding-bottom:calc(var(--eq-h) + 3vh)}
.hero-eyebrow{margin-bottom:2.2rem}
.hero h1{margin:0 0 1.6rem;max-width:14ch}
.hero h1 .fire{display:inline-block}
.hero .sub{margin-bottom:1.3rem}
.hero .lead{margin-bottom:2.6rem}
.hero-cta{display:flex;flex-wrap:wrap;gap:1rem;align-items:center}
.scroll-cue{display:flex;align-items:center;gap:.8em;margin-top:3.4rem;color:var(--gray)}
.scroll-cue .bar{position:relative;width:46px;height:2px;background:var(--line);overflow:hidden}
.scroll-cue .bar::after{content:"";position:absolute;inset:0;width:40%;background:var(--orange);animation:cue 1.8s ease-in-out infinite}
@keyframes cue{0%{transform:translateX(-110%)}60%,100%{transform:translateX(260%)}}

/* hero floating sticker */
.sticker{
  font-family:"JetBrains Mono",monospace;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  font-size:.7rem;padding:.55em .8em;border:2px solid var(--cream);border-radius:var(--radius);
  background:var(--bg);color:var(--cream);display:inline-block;line-height:1;
}
.sticker.fire{background:var(--orange);border-color:var(--orange);color:#160a04}
.hero-stickers{position:absolute;inset:0;pointer-events:none;z-index:2}
.hero-stickers .sticker{position:absolute}
.s-1{top:18%;right:6%;transform:rotate(8deg)}
.s-2{top:60%;right:11%;transform:rotate(-6deg)}
.s-3{top:38%;right:3%;transform:rotate(-3deg)}

/* ============ MARQUEE ============ */
.marquee{
  overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  background:var(--panel);padding-block:.9rem;position:relative;z-index:3;
  transform:skewX(var(--mskew,0deg));transition:transform .25s ease;
}
.marquee.fire{background:var(--orange)}
.marquee-track{display:inline-flex;white-space:nowrap;will-change:transform}
.marquee-track span{
  font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.6rem,4vw,2.8rem);
  letter-spacing:.02em;padding-inline:1.1rem;display:inline-flex;align-items:center;gap:1.1rem;color:var(--cream)
}
.marquee.fire .marquee-track span{color:#160a04}
.marquee-track .sep{color:var(--orange);font-size:.7em}
.marquee.fire .marquee-track .sep{color:#160a04}

/* ============ MANIFIESTO ============ */
.manifiesto{text-align:center}
.manifiesto .wrap{max-width:1100px}
.manifiesto h2{margin:0 auto 2rem;max-width:18ch}
.manifiesto .lead{margin-inline:auto;text-align:center}
.manifiesto .rule{width:90px;height:3px;background:var(--orange);margin:0 auto 2.4rem}

/* ============ CREDENCIALES ============ */
.cred-head{display:flex;flex-direction:column;gap:.4rem;margin-bottom:3.4rem}
.cred-head h2{max-width:16ch}
.cred-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
.cred-cell{padding:clamp(1.6rem,3vw,2.6rem);background:var(--panel)}
.cred-val{font-family:"Anton",sans-serif;font-size:clamp(2.6rem,6.5vw,5rem);line-height:.9;color:var(--cream)}
.cred-cell:nth-child(odd) .cred-val{color:var(--orange)}
.cred-val .plus{color:var(--orange2)}
.cred-label{font-family:"JetBrains Mono",monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);margin-top:.9rem}
.cred-label a{color:inherit;text-decoration:none;border-bottom:1px dotted var(--gray);transition:color .2s,border-color .2s}
.cred-label a:hover{color:var(--orange);border-bottom-color:var(--orange)}

/* ============ FAMILIAR (pain) ============ */
.familiar h2{margin-bottom:.6rem}
.familiar .intro{color:var(--gray);max-width:48ch;margin-bottom:3rem}
.pain-list{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border-top:1px solid var(--line)}
.pain{
  display:flex;gap:1.2rem;align-items:flex-start;padding:1.9rem 0;
  border-bottom:1px solid var(--line);
}
.pain:nth-child(odd){border-right:1px solid var(--line);padding-right:2.4rem}
.pain:nth-child(even){padding-left:2.4rem}
.pain .x{
  flex:none;width:34px;height:34px;border:2px solid var(--orange);border-radius:var(--radius);
  display:grid;place-items:center;color:var(--orange);font-family:"JetBrains Mono",monospace;font-weight:700;
  transform:rotate(-4deg);
}
.pain p{font-size:clamp(1.05rem,1.8vw,1.32rem);color:var(--cream)}
.pain p b{color:var(--orange2);font-weight:500}
.familiar .closer{margin-top:2.8rem;font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.4rem,3.4vw,2.4rem);line-height:1}
.familiar .closer .fire{color:var(--orange)}

/* ============ METHODS ============ */
.method{overflow:hidden}
.method .wrap{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(2rem,5vw,5rem);align-items:center}
.method .idx{font-family:"JetBrains Mono",monospace;color:var(--orange);letter-spacing:.2em;font-size:.8rem;margin-bottom:1.1rem}
.method .word{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(3.4rem,11vw,9rem);line-height:.92;letter-spacing:-.01em}
.method .kick{display:block;font-family:"JetBrains Mono",monospace;font-size:.8rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gray);margin-top:1.2rem}
.method .tag{font-size:clamp(1.2rem,2.4vw,1.7rem);color:var(--orange2);font-weight:500;margin:1.8rem 0 1.1rem}
.method .body{color:#cfc7b6;font-size:clamp(1rem,1.5vw,1.15rem);max-width:46ch}
.method .feats{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--line);border-radius:var(--radius)}
.feat{padding:1.35rem 1.4rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
.feat:nth-child(2n){border-right:none}
.feat:nth-child(n+3){border-bottom:none}
.feat .n{font-family:"JetBrains Mono",monospace;color:var(--orange);font-size:.72rem;letter-spacing:.18em}
.feat .t{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.1rem,2.2vw,1.5rem);margin-top:.5rem;line-height:1}
.method.flip .wrap{grid-template-columns:.95fr 1.05fr}
.method.flip .copy{order:2}
.method.flip .visual{order:1}
.visual{position:relative}
.frame{
  border:3px solid var(--cream);border-radius:var(--radius);padding:clamp(1.5rem,3vw,2.4rem);
  background:linear-gradient(160deg,#1c1411,#120d0b);box-shadow:10px 10px 0 var(--orange);position:relative;overflow:hidden;
}
.frame::after{content:"";position:absolute;inset:0;background:radial-gradient(70% 60% at 70% 20%, rgba(255,106,53,.16), transparent 60%);pointer-events:none}
.frame .biglabel{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(2.4rem,5.5vw,4rem);line-height:.86;color:var(--cream)}
.frame .biglabel .fire{color:var(--orange)}
.wave-svg{width:100%;height:88px;margin-top:1.4rem;display:block}
.wave-svg path{fill:none;stroke:var(--orange);stroke-width:3;stroke-linecap:round}
.wave-svg .w2{stroke:var(--cream);opacity:.5;stroke-width:2}

/* ============ PROCESO ============ */
.proceso h2{margin-bottom:3.2rem;max-width:14ch}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:2px solid var(--orange)}
.step{padding:2rem 1.6rem 2.4rem 0;border-right:1px solid var(--line);position:relative}
.step:last-child{border-right:none}
.step .num{font-family:"Anton",sans-serif;font-size:clamp(2.2rem,5vw,3.4rem);color:var(--orange);line-height:.9}
.step .t{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.15rem,2.4vw,1.6rem);margin:.9rem 0 .7rem;line-height:1}
.step p{color:var(--gray);font-size:.97rem}

/* ============ ANDRES ============ */
.andres .wrap{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(2rem,5vw,5rem);align-items:center}
.andres .portrait{
  position:relative;border:3px solid var(--cream);border-radius:var(--radius);
  background:linear-gradient(155deg,#241813,#16100d);box-shadow:12px 12px 0 var(--orange);
  aspect-ratio:4/5;display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(1.4rem,3vw,2.2rem);overflow:hidden;
}
.andres .portrait::before{
  content:"";position:absolute;inset:0;z-index:1;
  background:linear-gradient(180deg, rgba(13,11,10,.08) 0%, rgba(13,11,10,.5) 55%, rgba(13,11,10,.92) 100%);
  pointer-events:none;
}
.andres .portrait .pphoto{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 18%;filter:grayscale(.2) contrast(1.05);z-index:0}
.andres .portrait .monogram{display:none}
.andres .portrait .pname,.andres .portrait .prole,.andres .portrait .pstickers{z-index:2}
.andres .monogram{
  position:absolute;top:6%;left:50%;transform:translateX(-50%);
  font-family:"Anton",sans-serif;font-size:clamp(7rem,20vw,15rem);line-height:.8;color:rgba(243,237,224,.06);letter-spacing:-.04em;
}
.andres .pname{position:relative;font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(2.6rem,6vw,4.6rem);line-height:.86}
.andres .prole{position:relative;font-family:"JetBrains Mono",monospace;font-size:.74rem;letter-spacing:.2em;text-transform:uppercase;color:var(--orange2);margin-top:.7rem}
.andres .pstickers{position:absolute;inset:0;pointer-events:none}
.andres .pstickers .sticker{position:absolute}
.p-1{top:8%;right:7%;transform:rotate(7deg)}
.p-2{top:30%;left:7%;transform:rotate(-7deg)}
.andres h2{margin-bottom:1rem}
.andres .tag{font-size:clamp(1.3rem,2.6vw,1.9rem);color:var(--orange2);font-weight:500;margin-bottom:1.6rem;max-width:18ch}
.andres .body{color:#cfc7b6;font-size:clamp(1rem,1.5vw,1.15rem);max-width:52ch;margin-bottom:2rem}
.chips{display:flex;flex-wrap:wrap;gap:.6rem}
.chip{font-family:"JetBrains Mono",monospace;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--cream);border:1px solid var(--line);border-radius:var(--radius);padding:.55em .8em}
.chip b{color:var(--orange);font-weight:700}

/* ============ TESTIMONIOS ============ */
.testi-head{display:flex;flex-direction:column;align-items:flex-start;gap:1rem;margin-bottom:3rem}
.stars{display:inline-flex;gap:.25rem;color:var(--orange);font-size:1.3rem;letter-spacing:.1em}
.rating-line{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.6rem,4.4vw,3rem);line-height:.95}
.rating-line .fire{color:var(--orange)}
.rating-link{font-family:"JetBrains Mono",monospace;font-size:.78rem;letter-spacing:.08em;color:var(--orange);text-decoration:none;border-bottom:1px solid var(--orange);padding-bottom:2px;opacity:.9;transition:opacity .2s}
.rating-link:hover{opacity:1}
.testi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.4rem}
.testi{
  border:1px solid var(--line);border-radius:var(--radius);background:var(--panel);
  padding:clamp(1.5rem,3vw,2.2rem);position:relative;transition:transform .2s ease, border-color .2s ease;
}
.testi:hover{transform:translateY(-4px);border-color:var(--orange)}
.testi .stars{font-size:1rem;margin-bottom:1.1rem}
.testi blockquote{font-size:clamp(1.05rem,1.8vw,1.28rem);line-height:1.45;color:var(--cream);margin-bottom:1.4rem}
.testi .who{display:flex;justify-content:space-between;align-items:center;gap:1rem;border-top:1px solid var(--line);padding-top:1.1rem}
.testi .name{font-weight:700}
.testi .meta{font-family:"JetBrains Mono",monospace;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gray)}
.verif{position:absolute;top:0;right:1.4rem;transform:translateY(-50%) rotate(-3deg);font-family:"JetBrains Mono",monospace;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;background:var(--orange);color:#160a04;padding:.4em .65em;border-radius:var(--radius);font-weight:700}

/* ============ PRECIOS ============ */
.precios h2{margin-bottom:.4rem;max-width:12ch}
.precios .intro{color:var(--gray);margin-bottom:3.2rem;max-width:44ch}
.plans{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;align-items:stretch}
.plan{
  border:1px solid var(--line);border-radius:var(--radius);background:var(--panel);
  padding:clamp(1.7rem,3vw,2.4rem);display:flex;flex-direction:column;position:relative;transition:transform .2s ease, border-color .2s ease;
}
.plan:hover{transform:translateY(-5px)}
.plan .pname{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.6rem,3vw,2.2rem);line-height:.95}
.plan .hours{font-family:"JetBrains Mono",monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);margin-top:.55rem}
.plan .price{font-family:"Anton",sans-serif;font-size:clamp(2.8rem,6vw,4.2rem);line-height:.9;margin:1.5rem 0 .2rem;color:var(--cream)}
.plan .price .cur{color:var(--orange);font-size:.5em;vertical-align:.18em;margin-right:.08em}
.plan .per{font-family:"JetBrains Mono",monospace;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gray)}
.plan .blurb{color:#cfc7b6;margin:1.3rem 0 1.5rem;font-size:.98rem}
.plan ul{list-style:none;display:flex;flex-direction:column;gap:.75rem;margin-bottom:2rem}
.plan li{display:flex;gap:.7rem;align-items:flex-start;font-size:.95rem;color:var(--cream)}
.plan li::before{content:"";flex:none;width:8px;height:8px;background:var(--orange);margin-top:.5em;border-radius:1px}
.plan .btn{width:100%;justify-content:center;margin-top:auto}
.plan.feat{border-color:var(--orange);box-shadow:0 0 0 1px var(--orange), 0 22px 50px -22px rgba(232,80,31,.5);transform:translateY(-8px)}
.plan.feat:hover{transform:translateY(-13px)}
.plan .badge{position:absolute;top:0;left:50%;transform:translate(-50%,-50%);background:var(--orange);color:#160a04;font-family:"JetBrains Mono",monospace;font-weight:700;font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;padding:.5em .9em;border-radius:var(--radius);white-space:nowrap}

.trial{
  margin-top:1.8rem;border:2px dashed var(--orange);border-radius:var(--radius);
  background:linear-gradient(120deg,rgba(232,80,31,.08),transparent);
  padding:clamp(1.5rem,3vw,2.2rem);display:flex;flex-wrap:wrap;gap:1.4rem;align-items:center;justify-content:space-between;
}
.trial .tinfo{max-width:60ch}
.trial .tprice{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(1.4rem,3vw,2.1rem);line-height:1}
.trial .tprice .fire{color:var(--orange)}
.trial p{color:#cfc7b6;margin-top:.5rem;font-size:.97rem}
.trial .thint{color:#9b9384;font-size:.86rem;margin-top:.55rem}
.trial .tcta{display:flex;flex-direction:column;gap:.7rem;flex-shrink:0}
.trial .tcta .btn{justify-content:center;white-space:nowrap}
.pay{margin-top:2rem;display:flex;flex-wrap:wrap;gap:1rem 1.6rem;align-items:center;border-top:1px solid var(--line);padding-top:1.6rem}
.pay .pl{font-family:"JetBrains Mono",monospace;font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gray)}
.pay .pl b{color:var(--orange);font-weight:700;margin-right:.6em}
.pay .pchip{font-family:"JetBrains Mono",monospace;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;border:1px solid var(--line);border-radius:var(--radius);padding:.5em .8em}

/* ============ FAQ ============ */
.faq h2{margin-bottom:2.8rem;max-width:12ch}
.faq-list{border-top:1px solid var(--line)}
.faq-item{border-bottom:1px solid var(--line)}
.faq-q{
  width:100%;text-align:left;display:flex;justify-content:space-between;align-items:center;gap:1.5rem;
  padding:1.6rem 0;font-family:"Space Grotesk",sans-serif;font-weight:500;
  font-size:clamp(1.1rem,2.2vw,1.45rem);color:var(--cream);
}
.faq-q:hover{color:var(--orange2)}
.faq-q:focus-visible{outline:2px solid var(--orange2);outline-offset:4px}
.faq-q .ico{flex:none;width:30px;height:30px;border:2px solid var(--orange);border-radius:var(--radius);position:relative;transition:transform .3s ease, background-color .3s ease}
.faq-q .ico::before,.faq-q .ico::after{content:"";position:absolute;background:var(--orange);transition:opacity .3s, background-color .3s}
.faq-q .ico::before{left:50%;top:7px;bottom:7px;width:2px;transform:translateX(-50%)}
.faq-q .ico::after{top:50%;left:7px;right:7px;height:2px;transform:translateY(-50%)}
.faq-item.open .faq-q .ico{background:var(--orange);transform:rotate(180deg)}
.faq-item.open .faq-q .ico::before{opacity:0}
.faq-item.open .faq-q .ico::after{background:#160a04}
.faq-a{overflow:hidden;height:0}
.faq-a p{color:var(--gray);max-width:64ch;padding-bottom:1.7rem;font-size:1.02rem;line-height:1.55}

/* ============ CTA FINAL ============ */
.cta{text-align:center;overflow:hidden}
.cta .wrap{display:flex;flex-direction:column;align-items:center}
.cta h2{margin:0 auto 1.4rem;max-width:14ch}
.cta .sub{color:#cfc7b6;margin-bottom:2.6rem}
.cta .mono{color:var(--gray);margin-top:2.6rem;font-size:.74rem}

/* ============ FOOTER ============ */
footer{border-top:1px solid var(--line);background:#0b0908;padding-block:clamp(3rem,6vh,5rem);position:relative;z-index:1}
footer .wrap{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:2.4rem;align-items:start}
footer .brand{font-size:1.6rem;margin-bottom:1rem}
footer .ftag{color:var(--gray);max-width:34ch;font-size:.95rem}
footer .fcol h4{font-family:"JetBrains Mono",monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--orange2);margin-bottom:1rem}
footer .fcol p,footer .fcol a{display:block;color:var(--cream);font-size:.92rem;margin-bottom:.55rem}
footer .fcol a:hover{color:var(--orange2)}
.foot-bottom{margin-top:3rem;padding-top:1.6rem;border-top:1px solid var(--line);display:flex;flex-wrap:wrap;gap:1rem;justify-content:space-between;align-items:center}
.foot-bottom .mono{font-size:.68rem;color:var(--gray)}

/* reveal base states (only when JS+motion) */
.js-anim .reveal-title,
.js-anim .reveal-up,
.js-anim .reveal-stagger > *{opacity:0}

/* ============ RESPONSIVE ============ */
@media (max-width:1024px){
  .cred-grid{grid-template-columns:repeat(2,1fr)}
  .steps{grid-template-columns:repeat(2,1fr)}
  .step{border-bottom:1px solid var(--line);padding-right:1.6rem}
  .step:nth-child(2n){border-right:none}
  .step:nth-child(n+3){border-bottom:none}
  .plans{grid-template-columns:1fr;gap:1.2rem}
  .plan.feat{transform:none}
  .plan.feat:hover{transform:translateY(-5px)}
}
@media (max-width:860px){
  .nav-links a.lnk{display:none}
  .method .wrap,.method.flip .wrap,.andres .wrap{grid-template-columns:1fr;gap:2.4rem}
  .method.flip .copy{order:1}.method.flip .visual{order:2}
  .testi-grid{grid-template-columns:1fr}
  footer .wrap{grid-template-columns:1fr 1fr}
  .andres .portrait{aspect-ratio:3/2;max-width:480px}
  .hero-stickers{display:none}
}
@media (max-width:560px){
  .pain-list{grid-template-columns:1fr}
  .pain:nth-child(odd){border-right:none;padding-right:0}
  .pain:nth-child(even){padding-left:0}
  .method .feats{grid-template-columns:1fr}
  .feat{border-right:none}
  .feat:nth-child(n){border-bottom:1px solid var(--line)}
  .feat:last-child{border-bottom:none}
  footer .wrap{grid-template-columns:1fr}
  .cred-grid{grid-template-columns:1fr}
  .trial{flex-direction:column;align-items:flex-start}
  .btn{width:100%;justify-content:center}
  .hero-cta .btn{width:100%}
  .nav .btn{width:auto}
}

/* ============ REDUCED MOTION ============ */
@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto}
  .grain,.scroll-cue .bar::after{animation:none}
  .marquee-track{transform:none !important}
  *{transition-duration:.01ms !important}
}
.manifiesto .eyebrow::after,.cta .eyebrow::after{content:"";width:34px;height:2px;background:var(--orange);display:inline-block}
</style>
</head>
