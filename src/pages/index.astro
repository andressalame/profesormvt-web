          <li>4 horas · 4 clases al mes</li>
          <li>Una disciplina o mezcla</li>
          <li>Presencial u online</li>
          <li>Plan personalizado</li>
        </ul>
        <a href="https://wa.me/51989077928?text=Hola%20Andrés%2C%20me%20interesa%20el%20paquete%20Esencial%20S%2F250" class="precio-cta" target="_blank" rel="noopener">Reservar</a>
      </div>

      <div class="precio-card featured">
        <span class="badge-elegido">★ MÁS ELEGIDO</span>
        <span class="tier-label">Intensivo</span>
        <h3>8 horas / mes</h3>
        <p class="tier-detail">2 clases por semana · mejor progreso</p>
        <div class="precio-amount">
          <span class="currency">S/</span>450<span class="period">/mes</span>
