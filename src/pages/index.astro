<!-- GSAP -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script is:inline>
(function () {
  "use strict";

  var REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var hasGSAP = (typeof window.gsap !== 'undefined');

  /* ---------------- NAV scrolled state ---------------- */
  var nav = document.getElementById('nav');
  function onScrollNav(){
    if (window.scrollY > 40) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  }
  onScrollNav();
  window.addEventListener('scroll', onScrollNav, {passive:true});

  /* ---------------- FAQ accordion (works without GSAP) ---------------- */
  var faqItems = document.querySelectorAll('.faq-item');
  faqItems.forEach(function(item){
    var q = item.querySelector('.faq-q');
    var a = item.querySelector('.faq-a');
    q.addEventListener('click', function(){
      var willOpen = !item.classList.contains('open');
      // close others for clean accordion
      faqItems.forEach(function(other){
        if (other !== item && other.classList.contains('open')){
          other.classList.remove('open');
          other.querySelector('.faq-q').setAttribute('aria-expanded','false');
          animateFaq(other.querySelector('.faq-a'), false);
        }
      });
      item.classList.toggle('open', willOpen);
      q.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      animateFaq(a, willOpen);
    });
  });
  function animateFaq(el, open){
    if (hasGSAP && !REDUCED){
      if (open) gsap.to(el, {height:'auto', duration:0.42, ease:'power2.out'});
      else gsap.to(el, {height:0, duration:0.3, ease:'power2.in'});
    } else {
      el.style.height = open ? 'auto' : '0px';
    }
  }

  /* ---------------- EQUALIZER (canvas, reacts to scroll) ---------------- */
  var canvas = document.getElementById('eq');
  var ctx = canvas ? canvas.getContext('2d') : null;
  var W=0, H=0, dpr=1, grad=null;
  var BARS = 70;
  var vel = 0;      // smoothed scroll velocity 0..1
  var prog = 0;     // scroll progress 0..1
  var lastY = window.scrollY, lastT = performance.now();

  function sizeEq(){
    if (!canvas) return;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas.clientWidth; H = canvas.clientHeight;
    canvas.width = Math.max(1, Math.floor(W*dpr));
    canvas.height = Math.max(1, Math.floor(H*dpr));
    ctx.setTransform(dpr,0,0,dpr,0,0);
    grad = ctx.createLinearGradient(0,H,0,0);
    grad.addColorStop(0, '#ff6a35');
    grad.addColorStop(0.55, '#e8501f');
    grad.addColorStop(1, '#f3ede0');
    BARS = W < 520 ? 44 : (W < 900 ? 56 : 70);
  }

  // fallback scroll velocity if ScrollTrigger not present
  function rawVelocity(){
    var now = performance.now();
    var y = window.scrollY;
    var dt = Math.max(now - lastT, 16);
    var v = Math.abs(y - lastY) / dt; // px per ms
    lastY = y; lastT = now;
    var max = (document.documentElement.scrollHeight - window.innerHeight) || 1;
    prog = Math.min(Math.max(y / max, 0), 1);
    return Math.min(v / 3, 1);
  }

  function drawEq(t){
    if (!ctx) return;
    ctx.clearRect(0,0,W,H);
    vel *= 0.9; // decay
    var bw = W / BARS;
    for (var i=0;i<BARS;i++){
      var x = i*bw;
      // travelling base wave (shifts with scroll progress)
      var phase = i*0.34 + t*0.0022 + prog*Math.PI*5;
      var base = (Math.sin(phase)*0.5 + 0.5);
      var jitter = (Math.sin(i*0.7 + t*0.011)*0.5 + 0.5);
      var amp = base*0.30 + vel*0.62*jitter + 0.04;
      if (amp > 1) amp = 1;
      var h = 3 + amp * (H*0.92);
      ctx.globalAlpha = 0.22 + amp*0.78;
      ctx.fillStyle = grad;
      ctx.fillRect(x + bw*0.16, H - h, Math.max(1, bw*0.62), h);
    }
    ctx.globalAlpha = 1;
  }

  /* ---------------- MAIN ---------------- */
  function init(){
    sizeEq();

    if (!hasGSAP){
      // Static-friendly fallback: ensure everything visible, draw one idle eq frame.
      document.documentElement.classList.remove('js-anim');
      if (ctx){ vel=0.12; drawEq(0); }
      // simple rAF idle eq even without GSAP
      if (ctx && !REDUCED){
        (function loop(now){ vel = Math.max(vel, rawVelocity()); drawEq(now); requestAnimationFrame(loop); })(performance.now());
      }
      return;
    }

    gsap.registerPlugin(ScrollTrigger);
    var bg = document.getElementById('bgLayer');
    var glow = document.getElementById('glow');

    if (REDUCED){
      // Reveal everything, no scrubbing, gentle static atmosphere.
      gsap.set('.reveal-title, .reveal-up, .reveal-stagger > *', {opacity:1, clearProps:'transform,filter'});
      gsap.set(bg, {backgroundColor:'#16100c'});
      gsap.set(glow, {opacity:0.16});
      if (ctx){ vel=0.1; drawEq(0); }
      return;
    }

    /* --- title reveals: scale + blur to focus --- */
    gsap.utils.toArray('.reveal-title').forEach(function(el){
      gsap.fromTo(el,
        {opacity:0, scale:1.22, filter:'blur(16px)', yPercent:8},
        {opacity:1, scale:1, filter:'blur(0px)', yPercent:0, duration:1.1, ease:'power3.out',
         scrollTrigger:{trigger:el, start:'top 82%'}});
    });

    /* --- simple up reveals --- */
    gsap.utils.toArray('.reveal-up').forEach(function(el){
      gsap.fromTo(el,
        {opacity:0, y:34},
        {opacity:1, y:0, duration:0.9, ease:'power3.out',
         scrollTrigger:{trigger:el, start:'top 88%'}});
    });

    /* --- staggered groups --- */
    gsap.utils.toArray('.reveal-stagger').forEach(function(group){
      gsap.fromTo(group.children,
        {opacity:0, y:40},
        {opacity:1, y:0, duration:0.8, ease:'power3.out', stagger:0.09,
         scrollTrigger:{trigger:group, start:'top 84%'}});
    });

    /* --- animated counters --- */
    gsap.utils.toArray('.count').forEach(function(el){
      var end = parseInt(el.getAttribute('data-count'), 10) || 0;
      var obj = {v:0};
      gsap.to(obj, {v:end, duration:1.9, ease:'power2.out', snap:{v:1},
        scrollTrigger:{trigger:el, start:'top 88%'},
        onUpdate:function(){ el.textContent = Math.round(obj.v); }});
    });

    /* --- per-section background + spotlight + glow journey --- */
    gsap.utils.toArray('[data-bg]').forEach(function(sec){
      var col = sec.getAttribute('data-bg');
      var gi = parseFloat(sec.getAttribute('data-glow') || '0.12');
      var spot = sec.querySelector('.spot');
      ScrollTrigger.create({
        trigger: sec,
        start: 'top 65%',
        end: 'bottom 35%',
        onToggle: function(self){
          if (self.isActive){
            gsap.to(bg, {backgroundColor:col, duration:1.1, ease:'power2.out', overwrite:'auto'});
            gsap.to(glow, {opacity:gi, duration:1.1, ease:'power2.out', overwrite:'auto'});
          }
        }
      });
      if (spot){
        // spotlight "turns on" as the section enters the frame
        gsap.fromTo(spot, {opacity:0},
          {opacity:1, ease:'none',
           scrollTrigger:{trigger:sec, start:'top 80%', end:'top 30%', scrub:true}});
        gsap.to(spot, {opacity:0, ease:'none',
           scrollTrigger:{trigger:sec, start:'bottom 60%', end:'bottom 10%', scrub:true}});
      }
    });

    /* --- parallax on framed visuals + portrait --- */
    gsap.utils.toArray('.frame, .andres .portrait, .hero-stickers, .pstickers').forEach(function(el, i){
      var sect = el.closest('section') || el.closest('header');
      if (!sect) return;
      gsap.fromTo(el, {y: 50},
        {y: -50, ease:'none',
         scrollTrigger:{trigger:sect, start:'top bottom', end:'bottom top', scrub:1}});
    });

    /* --- marquees: continuous + velocity skew --- */
    var mqTracks = gsap.utils.toArray('.marquee-track');
    mqTracks.forEach(function(track, idx){
      var dir = (track.closest('.fire')) ? 1 : -1;
      gsap.fromTo(track, {xPercent: dir<0 ? 0 : -50},
        {xPercent: dir<0 ? -50 : 0, duration: 22, ease:'none', repeat:-1});
    });

    /* --- master scroll listener for eq + marquee skew --- */
    ScrollTrigger.create({
      start: 0, end: 'max',
      onUpdate: function(self){
        prog = self.progress;
        var v = Math.abs(self.getVelocity());
        var nv = Math.min(v / 1600, 1);
        if (nv > vel) vel = nv;
        var sk = self.getVelocity() / -340;
        if (sk > 6) sk = 6; if (sk < -6) sk = -6;
        document.documentElement.style.setProperty('--mskew', sk.toFixed(2)+'deg');
      }
    });

    // eq render loop
    (function loop(now){ drawEq(now); requestAnimationFrame(loop); })(performance.now());

    // refresh after fonts load (layout shift safe)
    if (document.fonts && document.fonts.ready){
      document.fonts.ready.then(function(){ ScrollTrigger.refresh(); });
    }
    window.addEventListener('load', function(){ ScrollTrigger.refresh(); });
  }

  // resize handling
  var rzT;
  window.addEventListener('resize', function(){
    clearTimeout(rzT);
    rzT = setTimeout(function(){
      sizeEq();
      if (hasGSAP && window.ScrollTrigger) ScrollTrigger.refresh();
    }, 180);
  });

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
