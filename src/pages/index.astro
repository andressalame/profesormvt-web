---
// Home oficial · ProfesorMVT — rediseño punk (reemplaza la versión anterior)
// Página standalone (sin Layout) para controlar 100% el diseño, conservando Meta Pixel + SEO.
const title = "Profesor MVT · Canto, piano y composición para adultos en Lima";
const description = "Clases 1 a 1 de canto (método MVT), piano y composición para adultos en Lima (San Isidro) y online. Con Andrés Salame, músico real. Prueba S/50 con diagnóstico vocal en PDF.";
const faqSchema = {
  "@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"¿Tengo que tener experiencia previa para empezar?","acceptedAnswer":{"@type":"Answer","text":"Para nada, ni en canto ni en piano. Más de la mitad de mis alumnos empiezan sin haber tomado clases nunca. El método se adapta a tu nivel."}},
    {"@type":"Question","name":"¿Cuánto tardo en tocar una canción en piano?","acceptedAnswer":{"@type":"Answer","text":"Con un buen entrenamiento de dedos, independencia y coordinación a dos manos, muchos alumnos adultos tocan su primera canción favorita en menos de un mes."}},
    {"@type":"Question","name":"¿Cuándo empezaré a notar el progreso?","acceptedAnswer":{"@type":"Answer","text":"En las primeras 2-3 clases ya notas cambios chicos pero claros. El progreso técnico medible se ve a las 6-8 semanas con práctica constante."}},
    {"@type":"Question","name":"¿Puedo combinar canto, piano y composición?","acceptedAnswer":{"@type":"Answer","text":"Sí. En el paquete Intensivo de 8h/mes puedes hacer 4h de canto, 2h de piano y 2h de composición."}},
    {"@type":"Question","name":"¿Las clases son online o presenciales?","acceptedAnswer":{"@type":"Answer","text":"Las dos. Presencial en San Isidro u online por Zoom o Meet. Para piano necesitas un teclado de mínimo 61 teclas con sensibilidad al toque."}},
    {"@type":"Question","name":"¿Cómo se paga? ¿Acepta moneda extranjera?","acceptedAnswer":{"@type":"Answer","text":"En Perú: Plin, Yape o Agora. Online: USD, EUR o MXN por Wise, PayPal o transferencia. El pago es al inicio del mes."}}
  ]
};
---
<!DOCTYPE html>
