<style>
footer {
  background: var(--color-ink-soft);
  color: var(--color-bone);
  padding: 80px 0 32px;
  position: relative;
  z-index: 2;
  border-top: 1px solid var(--color-line);
}
.footer-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 56px;
}
.footer-brand .logo {
  color: var(--color-bone);
  font-size: 26px;
  margin-bottom: 16px;
  font-family: 'Fraunces', serif;
  font-weight: 500;
  display: flex; align-items: baseline; gap: 8px;
}
.footer-brand .logo .mark { color: var(--color-ember); font-style: italic; }
.footer-brand .logo .dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--color-ember);
  display: inline-block;
  transform: translateY(-3px);
}
.footer-brand p {
  font-size: 14px;
  color: var(--color-bone-mute);
  line-height: 1.6;
  max-width: 340px;
  margin-bottom: 8px;
}
.footer-address {
  font-family: 'JetBrains Mono', monospace !important;
  font-size: 11px !important;
  color: var(--color-text-mute) !important;
  letter-spacing: 0.05em;
}
.footer-col h4 {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-ember);
  font-weight: 500;
  margin-bottom: 18px;
}
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: 10px; }
.footer-col ul li a {
  font-size: 14px;
  color: var(--color-bone-mute);
  transition: color 0.2s;
  display: flex;
  align-items: center;
}
.footer-col ul li a:hover { color: var(--color-ember); }
.footer-col ul li a svg { fill: var(--color-bone-mute); transition: fill 0.2s; }
.footer-col ul li a:hover svg { fill: var(--color-ember); }
.footer-bottom {
  border-top: 1px solid var(--color-line);
  padding-top: 28px;
  display: flex; justify-content: space-between; align-items: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--color-text-mute);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

@media (max-width: 960px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
}
@media (max-width: 540px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
}
</style>
