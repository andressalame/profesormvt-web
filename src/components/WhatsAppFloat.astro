---
// Botón flotante de WhatsApp - aparece en todas las páginas
const PHONE = '51989077928';
const TEXT = 'Hola Andrés, vengo de la web profesormvt.com y me interesa la clase de prueba S/50';
---

<a href={`https://wa.me/${PHONE}?text=${encodeURIComponent(TEXT)}`} class="wa-float" target="_blank" rel="noopener">
  <span class="pulse"></span>
  <svg viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.594 5.39l-.999 3.648 3.745-.978zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
  Escríbeme
</a>

<style>
.wa-float {
  position: fixed;
  bottom: 24px; right: 24px;
  z-index: 200;
  display: flex; align-items: center; gap: 12px;
  background: var(--color-ember);
  color: var(--color-bone);
  padding: 14px 22px 14px 18px;
  border-radius: 4px;
  box-shadow: 0 6px 24px rgba(208, 74, 28, 0.35), 0 2px 8px rgba(0,0,0,0.2);
  font-size: 14.5px; font-weight: 600;
  transition: transform 0.2s, box-shadow 0.2s;
  cursor: pointer;
  letter-spacing: 0.01em;
}
.wa-float:hover {
  transform: translateY(-2px);
  background: var(--wine-deep);
  box-shadow: 0 10px 32px rgba(208, 74, 28, 0.45), 0 2px 8px rgba(0,0,0,0.25);
}
.wa-float svg { width: 22px; height: 22px; fill: var(--color-bone); }
.wa-float .pulse {
  position: absolute; inset: 0;
  border-radius: 4px;
  background: var(--color-ember);
  opacity: 0.4;
  animation: pulse 2s infinite;
  z-index: -1;
}
@keyframes pulse {
  0% { transform: scale(1); opacity: 0.4; }
  100% { transform: scale(1.08); opacity: 0; }
}

@media (max-width: 960px) {
  .wa-float { bottom: 16px; right: 16px; padding: 12px 16px 12px 14px; font-size: 0; gap: 0; border-radius: 50%; width: 52px; height: 52px; justify-content: center; }
  .wa-float svg { width: 24px; height: 24px; }
}
</style>
